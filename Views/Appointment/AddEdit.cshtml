@model HospitalManagementSystem.Models.Appointment
@{
    Layout = null;
    bool isEdit = Model.AppointmentID != 0;
    var patients = ViewBag.Patients as List<HospitalManagementSystem.Models.Patient> ?? new List<HospitalManagementSystem.Models.Patient>();
    var doctors = ViewBag.Doctors as List<HospitalManagementSystem.Models.Doctor> ?? new List<HospitalManagementSystem.Models.Doctor>();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(isEdit ? "Edit Appointment" : "Add Appointment")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary px-4">
        <span class="navbar-brand fw-bold">🏥 Hospital Management System</span>
        <a href="/Appointment/Index" class="btn btn-outline-light btn-sm">Back to Appointments</a>
    </nav>
    <div class="container mt-4">
        <div class="card shadow-sm mx-auto" style="max-width:650px">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(isEdit ? "Edit Appointment" : "Add New Appointment")</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post" action="/Appointment/AddEdit">
                    <input type="hidden" name="AppointmentID" value="@Model.AppointmentID" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Patient</label>
                        <select name="PatientID" class="form-select" required>
                            <option value="0">-- Select Patient --</option>
                            @foreach (var p in patients)
                            {
                                <option value="@p.PatientID">@p.FirstName @p.LastName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Doctor</label>
                        <select name="DoctorID" class="form-select" required>
                            <option value="0">-- Select Doctor --</option>
                            @foreach (var d in doctors)
                            {
                                <option value="@d.DoctorID">Dr. @d.FirstName @d.LastName (@d.Specialization)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Appointment Date & Time</label>
                        <input type="datetime-local" name="AppointmentDate"
                               value="@Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <select name="Status" class="form-select">
                            <option value="Scheduled">Scheduled</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notes</label>
                        <textarea name="Notes" class="form-control" rows="3" placeholder="Any notes...">@Model.Notes</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(isEdit ? "Update" : "Add Appointment")</button>
                        <a href="/Appointment/Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>