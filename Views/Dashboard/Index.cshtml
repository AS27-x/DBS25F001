@{
    ViewData["Title"] = "Dashboard";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Hospital Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary px-4">
        <span class="navbar-brand fw-bold">🏥 Hospital Management System</span>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white">👤 @ViewBag.Username (@ViewBag.Role)</span>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
    </nav>

    <div class="container mt-4">
        <h4 class="mb-4">Welcome, @ViewBag.Username! 👋</h4>
        <div class="row g-4">
            <div class="col-md-3">
                <a href="/Patient/Index" class="text-decoration-none">
                    <div class="card text-center p-4 border-0 shadow-sm h-100">
                        <div style="font-size:40px">🧑‍⚕️</div>
                        <h6 class="mt-2 fw-bold">Patients</h6>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/Doctor/Index" class="text-decoration-none">
                    <div class="card text-center p-4 border-0 shadow-sm h-100">
                        <div style="font-size:40px">👨‍⚕️</div>
                        <h6 class="mt-2 fw-bold">Doctors</h6>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/Appointment/Index" class="text-decoration-none">
                    <div class="card text-center p-4 border-0 shadow-sm h-100">
                        <div style="font-size:40px">📅</div>
                        <h6 class="mt-2 fw-bold">Appointments</h6>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/Bill/Index" class="text-decoration-none">
                    <div class="card text-center p-4 border-0 shadow-sm h-100">
                        <div style="font-size:40px">💰</div>
                        <h6 class="mt-2 fw-bold">Billing</h6>
                    </div>
                </a>
            </div>
        </div>
    </div>
</body>
</html>