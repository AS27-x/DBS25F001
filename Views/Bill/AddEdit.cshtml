@model HospitalManagementSystem.Models.Bill
@{
    Layout = null;
    bool isEdit = Model.BillID != 0;
    var patients = ViewBag.Patients as List<HospitalManagementSystem.Models.Patient> ?? new List<HospitalManagementSystem.Models.Patient>();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(isEdit ? "Edit Bill" : "Add Bill")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary px-4">
        <span class="navbar-brand fw-bold">🏥 Hospital Management System</span>
        <a href="/Bill/Index" class="btn btn-outline-light btn-sm">Back to Billing</a>
    </nav>
    <div class="container mt-4">
        <div class="card shadow-sm mx-auto" style="max-width:600px">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(isEdit ? "Edit Bill" : "Add New Bill")</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post" action="/Bill/AddEdit">
                    <input type="hidden" name="BillID" value="@Model.BillID" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Patient</label>
                        <select name="PatientID" class="form-select" required>
                            <option value="0">-- Select Patient --</option>
                            @foreach (var p in patients)
                            {
                                <option value="@p.PatientID">@p.FirstName @p.LastName</option>
                            }
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-semibold">Total Amount (Rs.)</label>
                            <input type="number" name="TotalAmount" value="@Model.TotalAmount"
                                   class="form-control" step="0.01" min="0" required />
                        </div>
                        <div class="col">
                            <label class="form-label fw-semibold">Paid Amount (Rs.)</label>
                            <input type="number" name="PaidAmount" value="@Model.PaidAmount"
                                   class="form-control" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bill Date</label>
                        <input type="date" name="BillDate"
                               value="@Model.BillDate.ToString("yyyy-MM-dd")"
                               class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <select name="Status" class="form-select">
                            <option value="Unpaid">Unpaid</option>
                            <option value="Partial">Partial</option>
                            <option value="Paid">Paid</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(isEdit ? "Update Bill" : "Add Bill")</button>
                        <a href="/Bill/Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>