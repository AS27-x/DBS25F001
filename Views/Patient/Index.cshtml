@model List<HospitalManagementSystem.Models.Patient>
@{
    ViewData["Title"] = "Patients";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patients</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary px-4">
        <span class="navbar-brand fw-bold">🏥 Hospital Management System</span>
        <div class="d-flex gap-3">
            <a href="/Dashboard/Index" class="btn btn-outline-light btn-sm">🏠 Dashboard</a>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>🧑‍⚕️ Patients</h4>
            <a href="/Patient/AddEdit" class="btn btn-primary">+ Add Patient</a>
        </div>

        <!-- Search -->
        <form method="get" action="/Patient" class="mb-3 d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Search by name or phone..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a href="/Patient" class="btn btn-outline-secondary">Clear</a>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <!-- Table -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Date of Birth</th>
                            <th>Gender</th>
                            <th>Contact</th>
                            <th>Blood Group</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No patients found.</td></tr>
                        }
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>@p.PatientID</td>
                                <td>@p.FirstName @p.LastName</td>
                                <td>@p.DateOfBirth.ToString("dd MMM yyyy")</td>
                                <td>@(p.Gender == "M" ? "Male" : p.Gender == "F" ? "Female" : "Other")</td>
                                <td>@p.ContactNumber</td>
                                <td><span class="badge bg-danger">@p.BloodGroup</span></td>
                                <td>
                                    <a href="/Patient/AddEdit/@p.PatientID" class="btn btn-sm btn-warning">Edit</a>
                                    <a href="/Patient/Delete/@p.PatientID" class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this patient?')">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>