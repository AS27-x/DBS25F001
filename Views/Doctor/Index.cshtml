@model List<HospitalManagementSystem.Models.Doctor>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctors</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary px-4">
        <span class="navbar-brand fw-bold">🏥 Hospital Management System</span>
        <div class="d-flex gap-3">
            <a href="/Dashboard/Index" class="btn btn-outline-light btn-sm">🏠 Dashboard</a>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
    </nav>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>👨‍⚕️ Doctors</h4>
            <a href="/Doctor/AddEdit" class="btn btn-primary">+ Add Doctor</a>
        </div>
        <form method="get" action="/Doctor/Index" class="mb-3 d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or specialization..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a href="/Doctor/Index" class="btn btn-outline-secondary">Clear</a>
        </form>
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Specialization</th>
                            <th>Department</th>
                            <th>Contact</th>
                            <th>Email</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No doctors found.</td></tr>
                        }
                        @foreach (var d in Model)
                        {
                            <tr>
                                <td>@d.DoctorID</td>
                                <td>Dr. @d.FirstName @d.LastName</td>
                                <td>@d.Specialization</td>
                                <td>@d.DepartmentName</td>
                                <td>@d.ContactNumber</td>
                                <td>@d.Email</td>
                                <td>
                                    <a href="/Doctor/AddEdit/@d.DoctorID" class="btn btn-sm btn-warning">Edit</a>
                                    <a href="/Doctor/Delete/@d.DoctorID" class="btn btn-sm btn-danger" onclick="return confirm('Delete this doctor?')">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>